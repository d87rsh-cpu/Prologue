# Supabase (required for auth and data). Get these from your project at https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Set to false to require real login (by default auth is bypassed with a demo user for easy testing)
# VITE_BYPASS_AUTH=false
